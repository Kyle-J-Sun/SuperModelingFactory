include README.md
include LICENSE
include pyproject.toml
include setup.py
include requirements.txt

# Ship source and typing stubs in sdists/wheels. The project is distributed as
# an open-source Python package; no module sources are intentionally withheld.
recursive-include Modeling_Tool *.py *.pyi
recursive-include ExcelMaster *.py
recursive-include Report *.py

# Exclude development / backup / generated artifacts.
recursive-exclude Modeling_Tool/**/backup *
recursive-exclude Modeling_Tool/backup *
exclude Modeling_Tool/Core/test_remove_comments.py
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.so
global-exclude *.pyd
global-exclude *.c
global-exclude .DS_Store
